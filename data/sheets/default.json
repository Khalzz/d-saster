                  ],
                  "id": "434380cd-f499-4a07-848a-94757dccc9e8",
                  "settings": {
                    "description": "Saving throws represent a **character's ability to resist or avoid harmful effects**. Each saving throw is tied to one of the six ability scores (STR, DEX, CON, INT, WIS, CHA).\n\nThey are used to **determine if a character can withstand something happening to them** — spells, traps, poison, fear, or any forced effect.\n\n*The calculation of saving throw modifier is:*\n**(Stat mod)** + **(proficiency bonus if proficient)**",
                    "gap": 8,
                    "grow": false,
                    "padding": 8,
                    "title": "Saving throws",
                    "width": 0
                  },
                  "type": "section"
                },
                {
                  "children": [
                    {
                      "children": [],
                      "id": "36adf72a-6075-496f-a9f5-5245ee10f75c",
                      "settings": {
