                        "gap": 5,
                        "padding": 0
                      },
                      "type": "auto-skills"
                    }
                  ],
                  "id": "32717a86-e36e-429e-8a33-fa537f1be17a",
                  "settings": {
                    "description": "Skills represent **specific areas of expertise a character can train in**. Each skill is tied to one of the six ability scores (STR, DEX, CON, INT, WIS, CHA).\n\nThey are used to check how good a character did something, based on what skill correlates to the action he will perform.\n\n*The calculation of skills modifier its:*\n**(Stat mod)** + **(proficiency bonus if profficient)**",
                    "gap": 8,
                    "grow": true,
                    "padding": 8,
                    "title": "Skills",
                    "width": 0
                  },
                  "type": "section"
                },
